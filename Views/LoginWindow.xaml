<Window x:Class="CzurWpfDemo.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Tizimga kirish"
        Height="550" Width="420"
        Background="#0F1117"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="InputLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9CA3AF"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#1C1F2E"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#F3F4F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PasswordBox" TargetType="PasswordBox">
            <Setter Property="Background" Value="#1C1F2E"/>
            <Setter Property="Foreground" Value="#F3F4F6"/>
            <Setter Property="BorderBrush" Value="#374151"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="CaretBrush" Value="#F3F4F6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ScrollViewer x:Name="PART_ContentHost"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter Property="BorderBrush" Value="#2563EB"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Border Background="#1C1F2E" CornerRadius="16" Padding="36"
                VerticalAlignment="Center" HorizontalAlignment="Center"
                Width="340">
            <StackPanel>
                <!-- Logo / Title -->
                <TextBlock Text="CZUR ET24 Pro"
                           FontFamily="Segoe UI Light" FontSize="26"
                           Foreground="#F3F4F6"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4"/>
                <TextBlock Text="Undruv bo'limi boshqaruv tizimi"
                           FontFamily="Segoe UI" FontSize="12"
                           Foreground="#6B7280"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,32"/>

                <!-- Telefon -->
                <TextBlock Text="Telefon raqam" Style="{StaticResource InputLabel}"/>
                <TextBox x:Name="TxtPhone"
                         Style="{StaticResource InputBox}"
                         Margin="0,0,0,16"
                         MaxLength="12"/>

                <!-- Parol -->
                <TextBlock Text="Parol" Style="{StaticResource InputLabel}"/>
                <PasswordBox x:Name="TxtPassword"
                             Style="{StaticResource PasswordBox}"
                             Margin="0,0,0,8"/>

                <!-- Xatolik xabari -->
                <TextBlock x:Name="TxtError"
                           Foreground="#EF4444"
                           FontFamily="Segoe UI" FontSize="12"
                           TextWrapping="Wrap"
                           Margin="0,0,0,16"
                           Visibility="Collapsed"/>

                <!-- Kirish tugmasi -->
                <Button x:Name="BtnLogin" Content="Tizimga kirish"
                        Click="BtnLogin_Click"
                        Background="#2563EB" Foreground="White"
                        FontFamily="Segoe UI Semibold" FontSize="14"
                        Padding="0,12" Cursor="Hand"
                        BorderThickness="0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    CornerRadius="8"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="#1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter TargetName="Bd" Property="Background" Value="#374151"/>
                                    <Setter Property="Foreground" Value="#6B7280"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- Loading -->
                <TextBlock x:Name="TxtLoading"
                           Text="Yuklanmoqda..."
                           Foreground="#9CA3AF"
                           FontFamily="Segoe UI" FontSize="12"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
