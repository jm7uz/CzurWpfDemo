<Window x:Class="CzurWpfDemo.Views.DocumentsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Hujjatlar"
        Height="700" Width="1000"
        Background="#0F1117"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="#374151"/>
            <Setter Property="Foreground" Value="#D1D5DB"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="16,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#4B5563"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button Content="Orqaga" Style="{StaticResource SecondaryButton}"
                    Click="BtnBack_Click" DockPanel.Dock="Left"
                    VerticalAlignment="Center" Margin="0,0,16,0"/>
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Text="Hujjatlar"
                           FontFamily="Segoe UI Light" FontSize="26"
                           Foreground="#F3F4F6"/>
                <TextBlock x:Name="TxtSubtitle" Text=""
                           Foreground="#6B7280" FontFamily="Segoe UI"
                           FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Contract Info -->
        <Border Grid.Row="1" Background="#1C1F2E" CornerRadius="10"
                Padding="16" Margin="0,0,0,16">
            <WrapPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="Hujjat raqami" Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBlock x:Name="TxtDocNumber" Foreground="#F3F4F6" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="F.I.O" Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBlock x:Name="TxtClientName" Foreground="#F3F4F6" FontFamily="Segoe UI Semibold" FontSize="14"/>
                </StackPanel>
                <StackPanel Margin="0,0,32,0">
                    <TextBlock Text="Telefon" Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBlock x:Name="TxtPhone" Foreground="#F3F4F6" FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Holat" Foreground="#9CA3AF" FontFamily="Segoe UI" FontSize="11"/>
                    <TextBlock x:Name="TxtContractStatus" Foreground="#F3F4F6" FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
            </WrapPanel>
        </Border>

        <!-- Document Cards -->
        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="CardsPanel">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status Bar -->
        <Border Grid.Row="3" Background="#1C1F2E" CornerRadius="8"
                Padding="16,8" Margin="0,12,0,0">
            <TextBlock x:Name="TxtStatus" Text="Yuklanmoqda..."
                       Foreground="#6B7280" FontFamily="Segoe UI" FontSize="12"/>
        </Border>
    </Grid>
</Window>
