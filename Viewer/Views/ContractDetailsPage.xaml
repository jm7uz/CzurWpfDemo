<UserControl x:Class="CzurWpfDemo.Views.ContractDetailsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button x:Name="BtnBack" Content="&#8592; Orqaga" Style="{StaticResource SecondaryButton}"
                    Click="BtnBack_Click"
                    DockPanel.Dock="Left"
                    VerticalAlignment="Center" Margin="0,0,16,0"/>
            <Button x:Name="BtnScan" Content="&#128247; Skanerlash" Style="{StaticResource PrimaryButton}"
                    Click="BtnScan_Click"
                    DockPanel.Dock="Right"
                    Visibility="Collapsed"
                    VerticalAlignment="Center"/>
            <StackPanel>
                <TextBlock x:Name="TxtTitle" Text="Shartnomalar"
                           FontFamily="Segoe UI Light" FontSize="26"
                           Foreground="#F3F4F6"/>
                <TextBlock x:Name="TxtSubtitle" Text=""
                           Foreground="#6B7280" FontFamily="Segoe UI"
                           FontSize="12" Margin="0,2,0,0"/>
            </StackPanel>
        </DockPanel>

        <!-- Filtrlar -->
        <Border Grid.Row="1" Background="#1C1F2E" CornerRadius="10"
                Padding="16" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                <StackPanel x:Name="UserFilterPanel" Visibility="Collapsed" Margin="0,0,16,0">
                    <TextBlock Text="Xodim" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <ComboBox x:Name="CmbUser" Width="200" Height="30"
                              DisplayMemberPath="Name"
                              SelectionChanged="CmbUser_SelectionChanged"
                              Background="#252B3B" Foreground="#E5E7EB"
                              BorderBrush="#374151" FontFamily="Segoe UI" FontSize="13"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Qidirish" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <TextBox x:Name="TxtSearch" Style="{StaticResource FilterInput}" Width="200" Height="30"/>
                </StackPanel>
                <StackPanel Margin="0,0,12,0">
                    <TextBlock Text="Boshlanish sanasi" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DpFrom" Style="{StaticResource FilterDatePicker}" Width="150"/>
                </StackPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="Tugash sanasi" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <DatePicker x:Name="DpTo" Style="{StaticResource FilterDatePicker}" Width="150"/>
                </StackPanel>
                <Button Content="Qidirish" Style="{StaticResource ActionButton}"
                        Click="BtnSearch_Click" VerticalAlignment="Bottom" Margin="0,0,8,0"/>
                <Button Content="Tozalash" Style="{StaticResource SecondaryButton}"
                        Click="BtnReset_Click" VerticalAlignment="Bottom"/>
            </StackPanel>
        </Border>

        <!-- Jadval -->
        <Border Grid.Row="2" Background="#1C1F2E" CornerRadius="10" Padding="2">
            <DataGrid x:Name="DgContracts"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      MouseDoubleClick="DgContracts_MouseDoubleClick"
                      Cursor="Hand"
                      Background="Transparent"
                      BorderThickness="0"
                      GridLinesVisibility="Horizontal"
                      HorizontalGridLinesBrush="#2D3348"
                      RowBackground="#1C1F2E"
                      AlternatingRowBackground="#222638"
                      HeadersVisibility="Column"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      FontFamily="Segoe UI"
                      FontSize="12"
                      Foreground="#E5E7EB"
                      HorizontalScrollBarVisibility="Auto">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#161929"/>
                        <Setter Property="Foreground" Value="#9CA3AF"/>
                        <Setter Property="FontFamily" Value="Segoe UI Semibold"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderBrush" Value="#2D3348"/>
                        <Setter Property="BorderThickness" Value="0,0,0,1"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.CellStyle>
                    <Style TargetType="DataGridCell">
                        <Setter Property="Padding" Value="10,6"/>
                        <Setter Property="BorderThickness" Value="0"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="DataGridCell">
                                    <Border Padding="{TemplateBinding Padding}"
                                            Background="{TemplateBinding Background}">
                                        <ContentPresenter VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#2563EB"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.CellStyle>

                <DataGrid.RowStyle>
                    <Style TargetType="DataGridRow">
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#262A3E"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </DataGrid.RowStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Hujjat raqami" Binding="{Binding DocumentNumber}" Width="140"/>
                    <DataGridTextColumn Header="F.I.O" Binding="{Binding Name}" Width="*"/>
                    <DataGridTextColumn Header="Tug'ilgan sana" Binding="{Binding BirthDateFormatted}" Width="100"/>
                    <DataGridTextColumn Header="Manzil" Binding="{Binding Adres}" Width="180"/>
                    <DataGridTextColumn Header="Hujjat turi" Binding="{Binding DocType}" Width="120"/>
                    <DataGridTextColumn Header="Telefon (SMS)" Binding="{Binding TelNumberSms}" Width="120"/>
                    <DataGridTextColumn Header="Telefon" Binding="{Binding TelNumber}" Width="120"/>
                    <DataGridTextColumn Header="Sana" Binding="{Binding DateFormatted}" Width="120"/>
                    <DataGridTextColumn Header="Holat" Binding="{Binding Status}" Width="80"/>
                    <DataGridTextColumn Header="Mas'ul" Binding="{Binding ResponsibleWorker}" Width="130"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <!-- Status va Sahifalash -->
        <Border Grid.Row="3" Background="#1C1F2E" CornerRadius="8"
                Padding="16,8" Margin="0,12,0,0">
            <DockPanel>
                <TextBlock x:Name="TxtStatus" Text="Tayyor"
                           Foreground="#6B7280" FontFamily="Segoe UI" FontSize="12"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            DockPanel.Dock="Right" VerticalAlignment="Center">
                    <TextBlock x:Name="TxtPageInfo" Text="" Foreground="#6B7280"
                               FontFamily="Segoe UI" FontSize="12"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <Button x:Name="BtnPrev" Content="Oldingi"
                            Style="{StaticResource PaginationButton}"
                            Click="BtnPrev_Click" Margin="0,0,6,0"/>
                    <Button x:Name="BtnNext" Content="Keyingi"
                            Style="{StaticResource PaginationButton}"
                            Click="BtnNext_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>
