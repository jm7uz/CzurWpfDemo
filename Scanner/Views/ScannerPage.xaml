<UserControl x:Class="CzurWpfDemo.Views.ScannerPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
             PreviewMouseDown="Page_PreviewMouseDown">

    <UserControl.Resources>
        <!-- Crop thumb stili — faqat shu sahifada ishlatiladi -->
        <Style TargetType="Thumb">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Thumb">
                        <Ellipse Fill="#3B82F6" Stroke="White" StrokeThickness="2" Cursor="Cross"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Orqaga tugmasi (faqat shartnoma rejimida ko'rinadi) -->
            <Button x:Name="BtnBack" Grid.Column="0"
                    Content="&#8592; Orqaga"
                    Style="{StaticResource SecondaryButton}"
                    Click="BtnBack_Click"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Visibility="Collapsed"/>

            <StackPanel Grid.Column="1">
                <TextBlock Text="CZUR ET24 Pro" FontFamily="Segoe UI Light"
                           FontSize="28" Foreground="#F3F4F6"/>
                <TextBlock x:Name="TxtContractInfo" Text=""
                           FontFamily="Segoe UI" FontSize="13"
                           Foreground="#9CA3AF" Margin="0,4,0,0"
                           Visibility="Collapsed"/>
            </StackPanel>

            <!-- Chiqish tugmasi (faqat mustaqil rejimda) + Filial qidiruvi (shartnoma rejimida) -->
            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <!-- Mustaqil rejim: chiqish tugmasi -->
                <Button x:Name="BtnLogout"
                        Content="Chiqish"
                        Style="{StaticResource SecondaryButton}"
                        Click="BtnLogout_Click"
                        Visibility="Collapsed"/>

                <!-- Shartnoma rejimi: qidiruvli filial dropdown -->
                <StackPanel x:Name="BranchFilterPanel" Visibility="Collapsed">
                    <TextBlock Text="Filial:" Style="{StaticResource LabelText}" Margin="0,0,0,4"/>
                    <Grid Width="300" HorizontalAlignment="Left">

                        <!-- Trigger (combobox ko'rinishi) -->
                        <Border x:Name="BranchDropdownTrigger"
                                Background="#1C1F2E"
                                BorderBrush="#374151"
                                BorderThickness="1"
                                CornerRadius="6"
                                Padding="10,8"
                                Cursor="Hand"
                                MouseLeftButtonDown="BranchDropdown_Click">
                            <DockPanel LastChildFill="True">
                                <TextBlock Text="&#9660;" DockPanel.Dock="Right"
                                           Foreground="#6B7280" FontSize="9"
                                           VerticalAlignment="Center" Margin="8,0,0,0"/>
                                <TextBlock x:Name="TxtSelectedBranch"
                                           Text="Barcha filiallar"
                                           Foreground="#9CA3AF"
                                           FontFamily="Segoe UI" FontSize="13"
                                           VerticalAlignment="Center"
                                           TextTrimming="CharacterEllipsis"/>
                            </DockPanel>
                        </Border>

                        <!-- Qidiruvli popup -->
                        <Popup x:Name="BranchPopup"
                               PlacementTarget="{Binding ElementName=BranchDropdownTrigger}"
                               Placement="Bottom"
                               StaysOpen="True"
                               AllowsTransparency="True"
                               Opened="BranchPopup_Opened">
                            <Border Width="300"
                                    Background="#1A1D2E"
                                    BorderBrush="#4B5563"
                                    BorderThickness="1"
                                    CornerRadius="0,0,8,8"
                                    Padding="6">
                                <Border.Effect>
                                    <DropShadowEffect Color="Black" Opacity="0.5"
                                                      BlurRadius="20" ShadowDepth="8"/>
                                </Border.Effect>
                                <StackPanel>
                                    <!-- Qidiruv inputi -->
                                    <Border Background="#262A3E"
                                            BorderBrush="#374151"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Margin="0,0,0,6">
                                        <DockPanel Margin="10,7">
                                            <TextBlock Text="&#128269;" DockPanel.Dock="Left"
                                                       Foreground="#6B7280" FontSize="11"
                                                       VerticalAlignment="Center"
                                                       Margin="0,0,7,0"/>
                                            <TextBox x:Name="TxtBranchSearch"
                                                     Background="Transparent"
                                                     BorderThickness="0"
                                                     Foreground="#F3F4F6"
                                                     CaretBrush="#F3F4F6"
                                                     FontFamily="Segoe UI" FontSize="13"
                                                     VerticalAlignment="Center"
                                                     TextChanged="TxtBranchSearch_TextChanged"/>
                                        </DockPanel>
                                    </Border>

                                    <!-- Filiallar ro'yxati -->
                                    <ScrollViewer MaxHeight="300"
                                                  VerticalScrollBarVisibility="Auto">
                                        <StackPanel x:Name="BranchListPanel"/>
                                    </ScrollViewer>
                                </StackPanel>
                            </Border>
                        </Popup>

                    </Grid>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Asosiy kontent -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <!-- Sidebar (Hujjat turlari) -->
            <Border x:Name="SidebarPanel" Grid.Column="0"
                    Style="{StaticResource CardBorder}"
                    Margin="0,0,12,0"
                    Width="220"
                    Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Sarlavha + yuklanish holati belgisi -->
                    <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="True">
                        <TextBlock x:Name="TxtSidebarCheck"
                                   Text="&#10003;"
                                   Foreground="#10B981"
                                   FontSize="15" FontWeight="Bold"
                                   DockPanel.Dock="Right"
                                   VerticalAlignment="Center"
                                   Visibility="Collapsed"
                                   Margin="4,0,0,0"/>
                        <TextBlock Text="Hujjat Turlari"
                                   Style="{StaticResource LabelText}"
                                   FontSize="12" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </DockPanel>

                    <!-- Yuklanmoqda holati -->
                    <StackPanel x:Name="SidebarLoadingPanel" Grid.Row="1"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Border Width="36" Height="36"
                                Background="#2D3348" CornerRadius="18"
                                HorizontalAlignment="Center" Margin="0,0,0,8">
                            <TextBlock Text="&#8987;" FontSize="18"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="#6B7280"/>
                        </Border>
                        <TextBlock Text="Yuklanmoqda..."
                                   Foreground="#6B7280" FontFamily="Segoe UI"
                                   FontSize="11" HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- Kartalar (scroll bori, lekin ko'rinmaydi) -->
                    <ScrollViewer Grid.Row="1"
                                  x:Name="SidebarScroll"
                                  VerticalScrollBarVisibility="Hidden"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="Collapsed">
                        <StackPanel x:Name="SidebarCardsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Sidebar ochish/yopish tugmasi -->
            <Button x:Name="BtnToggleSidebar"
                    Grid.Column="1"
                    Content="&#9664;"
                    Width="30" Height="60"
                    VerticalAlignment="Top"
                    HorizontalAlignment="Left"
                    Margin="12,80,0,0"
                    Background="#1C1F2E"
                    Foreground="#9CA3AF"
                    BorderThickness="0"
                    Cursor="Hand"
                    FontSize="16"
                    Click="BtnToggleSidebar_Click"
                    Visibility="Collapsed"/>

            <!-- Kamera ko'rinishi -->
            <Border Grid.Column="1" Style="{StaticResource CardBorder}"
                    Padding="0" Margin="0,0,12,0" ClipToBounds="True">
                <Grid Background="#080B12">

                    <!-- Bo'sh holat (kamera yo'q) -->
                    <StackPanel x:Name="PlaceholderPanel"
                                HorizontalAlignment="Center" VerticalAlignment="Center">
                        <TextBlock Text="&#9608;" FontSize="56"
                                   HorizontalAlignment="Center" Foreground="#1E2333"/>
                        <TextBlock Text="Kamera ulanmoqda..."
                                   Foreground="#4B5563" FontFamily="Segoe UI"
                                   FontSize="14" HorizontalAlignment="Center"
                                   Margin="0,10,0,0"/>
                    </StackPanel>

                    <!-- Kamera oqimi -->
                    <Viewbox Stretch="Uniform">
                        <Grid x:Name="CameraGrid">
                            <Image x:Name="CameraImage"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   Visibility="Collapsed"/>
                            <Canvas x:Name="LiveCropCanvas" Visibility="Collapsed"
                                    HorizontalAlignment="Left" VerticalAlignment="Top">

                                <!-- Hujjat atrofi qoraytirilgan overlay (EvenOdd cutout) -->
                                <Path x:Name="OverlayDim"
                                      Fill="#AA030508"
                                      IsHitTestVisible="False"/>

                                <!-- Hujjat chegarasi -->
                                <Polygon x:Name="LiveCropPolygon"
                                         Stroke="#60A5FA" StrokeThickness="1.5"
                                         Fill="Transparent" IsHitTestVisible="False"/>

                                <!-- Burchak L-belgilari -->
                                <Path x:Name="CornersPath"
                                      Stroke="White" StrokeThickness="3"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Fill="Transparent"
                                      IsHitTestVisible="False">
                                    <Path.Effect>
                                        <DropShadowEffect Color="#60A5FA" BlurRadius="8"
                                                          ShadowDepth="0" Opacity="0.8"/>
                                    </Path.Effect>
                                </Path>

                                <!-- Skanerlash chizig'i -->
                                <Rectangle x:Name="ScanLine" Height="2"
                                           Opacity="0" IsHitTestVisible="False">
                                    <Rectangle.Fill>
                                        <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <GradientStop Color="Transparent"  Offset="0"/>
                                            <GradientStop Color="#6060A5FA"    Offset="0.2"/>
                                            <GradientStop Color="#DDFFFFFF"    Offset="0.5"/>
                                            <GradientStop Color="#6060A5FA"    Offset="0.8"/>
                                            <GradientStop Color="Transparent"  Offset="1"/>
                                        </LinearGradientBrush>
                                    </Rectangle.Fill>
                                    <Rectangle.Effect>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="10"
                                                          ShadowDepth="0" Opacity="1"/>
                                    </Rectangle.Effect>
                                </Rectangle>

                                <!-- Qo'lda crop thumb lari -->
                                <Thumb x:Name="ThumbTL" Width="30" Height="30"
                                       DragDelta="Thumb_DragDelta" Tag="0" Visibility="Collapsed"/>
                                <Thumb x:Name="ThumbTR" Width="30" Height="30"
                                       DragDelta="Thumb_DragDelta" Tag="1" Visibility="Collapsed"/>
                                <Thumb x:Name="ThumbBR" Width="30" Height="30"
                                       DragDelta="Thumb_DragDelta" Tag="2" Visibility="Collapsed"/>
                                <Thumb x:Name="ThumbBL" Width="30" Height="30"
                                       DragDelta="Thumb_DragDelta" Tag="3" Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>
                    </Viewbox>

                    <!-- Tugmalar — kamera ustiga floating pill -->
                    <Border VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Margin="0,0,0,18">
                        <Border Background="#D0080B12" CornerRadius="30"
                                BorderBrush="#2D3555" BorderThickness="1"
                                Padding="14,8">
                            <Border.Effect>
                                <DropShadowEffect Color="Black" BlurRadius="28"
                                                  ShadowDepth="0" Opacity="0.7"/>
                            </Border.Effect>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Button x:Name="BtnStart" Visibility="Collapsed" Click="BtnStart_Click"/>
                                <Button x:Name="BtnStop"  Visibility="Collapsed" Click="BtnStop_Click"/>
                                <Button x:Name="BtnManualCrop"
                                        Content="✏  Qo'lda"
                                        Style="{StaticResource PrimaryButton}"
                                        Background="#5B21B6"
                                        Click="BtnManualCrop_Click"
                                        IsEnabled="False" Margin="0,0,8,0"/>
                                <Button x:Name="BtnCapture"
                                        Content="📷  Rasmga olish"
                                        Style="{StaticResource PrimaryButton}"
                                        Click="BtnCapture_Click" IsEnabled="False"/>
                            </StackPanel>
                        </Border>
                    </Border>

                </Grid>
            </Border>

            <!-- O'ng panel -->
            <StackPanel Grid.Column="2">
                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Holat:" Style="{StaticResource LabelText}" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtStatus" Text="Tayyor"
                                   Style="{StaticResource ValueText}"
                                   Foreground="#10B981" Margin="0,0,0,10"/>
                        <TextBlock Text="FPS:" Style="{StaticResource LabelText}" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtFps" Text="&#8212;"
                                   Style="{StaticResource ValueText}" Margin="0,0,0,10"/>
                        <TextBlock Text="Olingan Rasmlar:" Style="{StaticResource LabelText}" Margin="0,0,0,2"/>
                        <TextBlock x:Name="TxtCaptureCount" Text="0"
                                   Style="{StaticResource ValueText}"/>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource CardBorder}" Margin="0,0,0,12">
                    <StackPanel>
                        <TextBlock Text="Oxirgi Rasm"
                                   Style="{StaticResource LabelText}"
                                   Margin="0,0,0,8" FontSize="13"/>
                        <Border Background="#0A0D14" CornerRadius="6" Height="150">
                            <Image x:Name="CapturedImage"
                                   Stretch="Uniform"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <Button x:Name="BtnSave" Content="PDF qilib saqlash"
                                Style="{StaticResource PrimaryButton}"
                                Click="BtnSave_Click" IsEnabled="False"
                                Margin="0,10,0,0"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- Log satri -->
        <Border Grid.Row="2" Background="#1C1F2E" CornerRadius="8"
                Padding="16,10" Margin="0,12,0,0">
            <TextBlock x:Name="TxtLog"
                       Text="Tayyor. Kamera ulanmoqda..."
                       Foreground="#6B7280" FontFamily="Consolas"
                       FontSize="12" TextWrapping="Wrap"/>
        </Border>
    </Grid>
</UserControl>
